# ================================
# DATABASE CONFIGURATION
# ================================

USE_PG=true
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=bot_wa
PG_USER=your_db_user
PG_PASSWORD=your_db_password
PG_SSL=false
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONN_TIMEOUT_MS=15000
PG_STATEMENT_TIMEOUT_MS=60000
PG_KEEPALIVE=true
PG_WARMUP_CONNECTIONS=3
PG_QUERY_RETRIES=2
PG_SLOW_MS=1500
PG_UPSERT_CHUNK=100

# ================================
# REDIS CONFIGURATION
# ================================

REDIS=ON
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ================================
# PAYMENT GATEWAY (MIDTRANS)
# ================================

MIDTRANS_MERCHANT_ID=your_merchant_id
MIDTRANS_SERVER_KEY=your_midtrans_server_key
MIDTRANS_CLIENT_KEY=your_midtrans_client_key
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_PRODUCTION=false
MIDTRANS_STATIC_QRIS=your_static_qris_code
MIDTRANS_USE_STATIC_ONLY=true

# ================================
# CLOUDFLARE R2 STORAGE
# ================================

R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://your-r2-public-url
R2_ENABLED=true
R2_FALLBACK_TO_LOCAL=false

# ================================
# TELEGRAM NOTIFICATIONS
# ================================

TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ================================
# BOT CONFIGURATION
# ================================

BOT_NAME=My Bot
BOT_PAIRING_CODE=true
BOT_BACKUP_HOURS=12

OWNER_NUMBERS=628123456789
OWNER_NUMBER=628123456789
OWNER_NAME=Owner

BOT_PACKNAME=
BOT_AUTHOR=Owner
BOT_SESSION_NAME=session

BOT_GROUP_LINKS=https://chat.whatsapp.com/invite1
BOT_GROUP_NAMES=Group Name 1,Group Name 2

# ================================
# ORDER KUOTA
# ================================

ORDER_KUOTA_MEMBER_ID=
ORDER_KUOTA_PIN=
ORDER_KUOTA_PASSWORD=

# ================================
# PAYMENT INFO
# ================================

PAYMENT_QRIS_NAME=Your Name
PAYMENT_DANA_NUMBER=08xxxxxxxxxx
PAYMENT_DANA_NAME=Your Name
PAYMENT_GOPAY_NUMBER=08xxxxxxxxxx
PAYMENT_GOPAY_NAME=Your Name
PAYMENT_OVO_NUMBER=08xxxxxxxxxx
PAYMENT_OVO_NAME=Your Name

# ================================
# PROFIT & FEE
# ================================

FEE_DEPO=2
PROFIT_TYPE=persen
PROFIT_BRONZE_PERCENT=2
PROFIT_SILVER_PERCENT=1.5
PROFIT_GOLD_PERCENT=1
PROFIT_BRONZE_NOMINAL=1000
PROFIT_SILVER_NOMINAL=500
PROFIT_GOLD_NOMINAL=200
UPGRADE_SILVER_PRICE=100000
UPGRADE_GOLD_PRICE=200000

# ================================
# LISTENER BACKEND
# ================================

LISTENER_BASE_URL=https://your-listener-url
LISTENER_API_KEY=your_api_key

# ================================
# GOWA WHATSAPP SERVICE
# ================================

GOWA_API_URL=https://your-gowa-api-url
GOWA_USERNAME=admin
GOWA_PASSWORD=your_gowa_password
GOWA_DEVICE_ID=default
GOWA_WEBHOOK_SECRET=your_webhook_secret
